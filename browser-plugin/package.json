{
  "name": "nink-browser-plugin",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web3": "esbuild src/utils/web3Bridge.source.js --bundle --format=esm --platform=browser --outfile=src/utils/web3Bridge.js --external:chrome --external:../config/chainConfig.js",
    "build:local-anchor": "esbuild src/utils/localChainAnchor.source.js --bundle --format=esm --platform=browser --outfile=src/utils/localChainAnchor.js --external:chrome --external:../config/chainConfig.js",
    "build:extension": "npm run build:web3 && npm run build:local-anchor"
  },
  "dependencies": {
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
